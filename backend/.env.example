# App Config
PROJECT_NAME="UnivGPT"
ENVIRONMENT="development"
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"
FRONTEND_APP_URL="http://localhost:5173"
OAUTH_REDIRECT_PATH="/auth/callback"
ACADEMIC_EMAIL_DOMAINS=""
REQUIRE_VERIFIED_ACADEMIC_EMAIL_FOR_QUERIES=false
DEAN_EMAILS="jsoncoder08@gmail.com"

# --- SUPABASE (Primary Data & Auth) ---
# Replace with your Supabase credentials
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_JWT_SECRET="your-jwt-secret"
SUPABASE_OFFLINE_MODE=false
ENABLE_DUMMY_AUTH=false

# --- PINECONE (Vector Storage) ---
# Better performance (40ms) and 2GB free storage
PINECONE_API_KEY="your-pinecone-api-key"
PINECONE_INDEX_NAME="unigpt-index"

# --- AI & EMBEDDINGS (Local & Free) ---
# Embedding Model: local HuggingFace (0 cost, no API limits)
EMBEDDING_MODEL_NAME="all-MiniLM-L6-v2"
PRELOAD_EMBEDDINGS_ON_STARTUP=true

# LLM: Using OpenRouter (e.g., Llama 3)
OPENROUTER_API_KEY="your-open-router-api-key"
OPENROUTER_MODEL="z-ai/glm-4.5-air:free"
OPENROUTER_INTENT_MODEL="z-ai/glm-4.5-air:free"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_FALLBACK_MODELS=""
OPENROUTER_TIMEOUT_SECONDS=20
OPENROUTER_MAX_RETRIES=2
OPENROUTER_RETRY_BACKOFF_SECONDS=0.8

# --- DEVELOPMENT ---
MOCK_LLM=false

# --- SMTP (Email) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
# For Gmail SMTP, keep FROM_EMAIL the same as SMTP_USER.
SMTP_FROM_EMAIL="your-email@gmail.com"
SMTP_FROM_NAME="UnivGPT Support"
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=20
